{
    "name": "vue-template-project",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write \"src/**/*.{js,ts,vue,css,scss,html,json}\"",
        "format:check": "prettier --check \"src/**/*.{js,ts,vue,css,scss,html,json}\"",
        "prepare": "husky",
        "type-check": "vue-tsc --noEmit"
    },
    "dependencies": {
        "axios": "^1.9.0",
        "lodash": "^4.17.21",
        "vue": "^3.5.14",
        "vue-router": "^4.5.1"
    },
    "devDependencies": {
        "@craig37/lint-config": "^1.0.7",
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.27.0",
        "@types/lodash": "^4.17.17",
        "@types/node": "^22.15.21",
        "@vitejs/plugin-vue": "^5.2.4",
        "@vue/tsconfig": "^0.7.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-prettier": "^5.4.0",
        "eslint-plugin-vue": "^10.1.0",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "prettier": "^3.5.3",
        "lint-staged": "^16.0.0",
        "sass": "^1.77.0",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.32.1",
        "unplugin-auto-import": "^19.2.0",
        "unplugin-vue-components": "^28.5.0",
        "vite": "^6.3.5",
        "vite-plugin-compression": "^0.5.1",
        "vite-plugin-prettier-dts": "^0.1.10",
        "vite-svg-loader": "^5.1.0",
        "vue-eslint-parser": "^10.1.3",
        "vue-tsc": "^2.2.0"
    },
    "packageManager": "pnpm@10.11.0+sha512.6540583f41cc5f628eb3d9773ecee802f4f9ef9923cc45b69890fb47991d4b092964694ec3a4f738a420c918a333062c8b925d312f42e4f0c263eb603551f977",
    "lint-staged": {
        "src/**/*.{js,cjs,ts,vue}": [
            "eslint --fix"
        ],
        "src/**/*.{html,json,css,scss}": [
            "prettier --write"
        ]
    }
}
